import spacy
nlp = spacy.load("en_core_web_sm")


headlines = [
    "Prime Minister Narendra Modi visited New York for the UN meeting.",
    "Microsoft announced a new AI tool in California.",
    "Virat Kohli scored a century against Australia in Mumbai.",
    "NASA plans a new mission to Mars next year."
]


for i, headline in enumerate(headlines, 1):


    doc = nlp(headline)


    print(f"\nHeadline {i}: {headline}")
    print("Named Entities:")


    for ent in doc.ents:
        print(f"{ent.text} --> {ent.label_}")
